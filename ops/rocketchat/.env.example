# Docker Compose env template (IMP-03 / IMP-15)
# Prefer: scripts/generate_compose_env.sh → .env (mode 600)
# Use branded *.ngrok.app only. NEVER *.ngrok-free.dev (Charter Cujo blocks the old free domain).
# Canonical host: see PUBLIC_DOMAIN (velocityworks-rc.ngrok.app)
ROOT_URL=https://velocityworks-rc.ngrok.app
ADMIN_USERNAME=principal
ADMIN_PASS=CHANGE_ME
ADMIN_EMAIL=principal@localhost.local
RC_PORT_BIND=127.0.0.1
